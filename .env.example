# Copy to .env and fill in. Loaded by structura.config.

# --- Input (WebODM raster products land here) ---
STRUCTURA_INPUT_DIR=./data/incoming

# --- 2D segmentation backend: "classical" (default), "sam" or "cellpose" ---
# "sam" needs `pip install -e ".[sam]"`, "cellpose" needs ".[cellpose]".
STRUCTURA_2D_BACKEND=classical
# Use GPU for the sam/cellpose backends (true/false).
STRUCTURA_GPU=false

# --- Output sink: "file" (GeoPackage/GeoJSON, default), "postgis" (direct) or "api" (Django) ---
STRUCTURA_SINK=file

# --- File sink (when STRUCTURA_SINK=file) — format from extension (.gpkg / .geojson) ---
STRUCTURA_OUTPUT_PATH=./data/output/features.gpkg

# --- PostGIS (when STRUCTURA_SINK=postgis) ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=excavation
PGUSER=structura
PGPASSWORD=
# PostGIS schema/table for vector features
STRUCTURA_PG_SCHEMA=public
STRUCTURA_PG_TABLE=features

# --- Django API (when STRUCTURA_SINK=api) ---
STRUCTURA_API_BASE_URL=http://localhost:8000/api
STRUCTURA_API_TOKEN=
